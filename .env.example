PORT=3000
HOST=127.0.0.1
APP_ENV=development
APP_BASE_URL=http://127.0.0.1:3000
DATABASE_URL=file:../../../data/office-agent.db
LOG_LEVEL=info
CONFIG_DIR=./config
TASK_ARTIFACT_DIR=./data/task-artifacts
SCREENSHOT_DIR=./data/screenshots
SCHEDULER_ENABLED=true
SCHEDULER_STATE_FILE=./data/scheduler-state.json
SCHEDULER_HOT_TOPICS_ENABLED=true
SCHEDULER_HOT_TOPICS_TIMES=00:00,04:00,08:00,12:00,16:00,20:00
WEATHER_ALERT_ENABLED=true
WEATHER_ALERT_LOCATION=合肥
WEATHER_ALERT_LATITUDE=31.8206
WEATHER_ALERT_LONGITUDE=117.2272
WEATHER_ALERT_CHECK_INTERVAL_MINUTES=30
WEATHER_ALERT_WINDOW_HOURS=6
LOCAL_ACCESS_WORKSPACE_ROOT=.
LOCAL_ACCESS_CODEX_MODE=disabled
LOCAL_ACCESS_CODEX_COMMAND=codex
LOCAL_ACCESS_CODEX_ARGS=
LOCAL_ACCESS_GEMINI_MODE=disabled
LOCAL_ACCESS_GEMINI_COMMAND=gemini
LOCAL_ACCESS_GEMINI_ARGS=

# --- 飞书配置（推送必需：需要同时配置 APP_ID、APP_SECRET 和 DEFAULT_CHAT_ID 才能正常推送） ---
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_USE_LONG_CONNECTION=false
FEISHU_DEFAULT_CHAT_ID=

CDP_BROWSER_COMMAND=microsoft-edge
STARTUP_BROWSER_UI=visible
STARTUP_OPEN_CHATGPT=true
STARTUP_OPEN_GEMINI=true
STARTUP_OPEN_DOUBAO=true

CODEX_RUNNER_ENABLED=false
CODEX_RUNNER_MODE=artifacts_only
CODEX_COMMAND=codex
CODEX_ARGS=
GEMINI_RUNNER_ENABLED=false
GEMINI_COMMAND=gemini
GEMINI_ARGS=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=
GEMINI_API_MODEL=gemini-2.5-flash-lite
GEMINI_API_MODEL_STANDARD=gemini-2.5-flash-lite
GEMINI_API_MODEL_PRO=gemini-2.5-flash
GEMINI_API_MODEL_EXPERT=gemini-2.5-flash
GEMINI_API_MODEL_DEEP=gemini-2.5-flash
GOLD_ALERT_ENABLED=true
GOLD_ALERT_CHECK_INTERVAL_MINUTES=120
GOLD_ALERT_THRESHOLD_CNY=15
GOLD_ALERT_ROUTINE_PUSH_INTERVAL_HOURS=6
